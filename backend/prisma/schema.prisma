  transactions LoyaltyTransaction[]

  @@index([userId])
  @@map("loyalty_points")
}

model LoyaltyTransaction {
  id              String   @id @default(uuid())
  loyaltyPointsId String
  orderId         String?
  points          Int // Positive for earned, negative for spent
  type            String // "EARNED" | "SPENT" | "EXPIRED" | "ADJUSTMENT"
  description     String?  @db.Text
  createdAt       DateTime @default(now())

  loyaltyPoints LoyaltyPoints @relation(fields: [loyaltyPointsId], references: [id], onDelete: Cascade)

  @@index([loyaltyPointsId])
  @@index([orderId])
  @@map("loyalty_transactions")
}

// Email Notifications
model EmailNotification {
  id        String    @id @default(uuid())
  userId    String?
  orderId   String?
  type      String // "ORDER_CONFIRMATION" | "SHIPPING" | "PASSWORD_RESET" | etc.
  subject   String
  body      String    @db.Text
  status    String    @default("PENDING") // "PENDING" | "SENT" | "FAILED"
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("email_notifications")
}

// Email Templates
model EmailTemplate {
  id          String   @id @default(uuid())
  type        String   @unique // "PASSWORD_RESET" | "WELCOME" | "ORDER_CONFIRMATION" | "SHIPPING" | "DELIVERY" | "PAYMENT_REQUEST" | "PAYMENT_CONFIRMED" | "RETURN_NOTIFICATION" | "PROMOTIONAL"
  subject     String   @db.Text
  htmlContent String   @db.Text
  textContent String?  @db.Text
  enabled     Boolean  @default(true)
  description String?  @db.Text
  variables   Json? // Available variables for this template type (e.g., {userName, resetToken, orderNumber, etc.})
  translations Json? // Per-locale overrides: { "ru": { subject, htmlContent, textContent }, "de": { ... } }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String? // Admin user ID

  @@index([type])
  @@index([enabled])
  @@map("email_templates")
}

// Feature Settings
model FeatureSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json // Can be boolean, string, number, or object
  description String?  @db.Text
  category    String // "FEATURES" | "PAYMENT" | "LOYALTY" | "UI" | etc.
  updatedAt   DateTime @updatedAt
  updatedBy   String? // Admin user ID

  @@index([key])
  @@index([category])
  @@map("feature_settings")
}

// Header Settings
model HeaderSettings {
  id                       String   @id @default(uuid())
  isActive                 Boolean  @default(true)
  // Logo settings
  logoType                 String   @default("TEXT") // "TEXT" | "IMAGE" | "SVG"
  logoText                 String   @default("LOGO")
  logoImageUrl             String?
  logoSvg                  String?  @db.Text
  logoPosition             String   @default("CENTER") // "LEFT" | "CENTER" | "RIGHT"
  logoSize                 String   @default("text-2xl") // Tailwind classes
  logoColor                String   @default("#000000")
  logoLink                 String   @default("/")
  // Header styling
  backgroundColor          String   @default("#ffffff")
  backgroundOpacity        Int      @default(92)
  backdropBlur             Int      @default(12)
  dropdownBackgroundOpacity Int      @default(96)
  dropdownBackdropBlur     Int      @default(16)
  textColor                String   @default("#000000")
  borderColor              String   @default("#e5e7eb")
  shadowEnabled            Boolean  @default(true)
  stickyEnabled            Boolean  @default(true)
  height                   String   @default("h-12") // Tailwind classes
  // Category links settings
