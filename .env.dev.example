# Local Docker development stack
# Usage:
#   cp .env.dev.example .env.dev
#   docker compose --env-file .env.dev -f docker-compose.dev.yml up --build

# --- App URLs / ports ---
FRONTEND_PORT=8080
BACKEND_PORT=3001
PUBLIC_SITE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080
VITE_API_URL=/api

# --- PostgreSQL ---
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fashion_dev_db
POSTGRES_PORT=15432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fashion_dev_db?schema=public
RAG_ENABLED=false
RAG_DATABASE_URL=postgresql://postgres:postgres@postgres-rag:5432/fashion_rag_dev_db?schema=public
RAG_DATABASE_DIRECT_URL=postgresql://postgres:postgres@postgres-rag:5432/fashion_rag_dev_db?schema=public
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_RETRIEVAL_TOP_K=8
RAG_RETRIEVAL_MIN_SCORE=0.2
RAG_HYBRID_SEARCH_ENABLED=true
RAG_RERANK_ENABLED=false
RAG_CITATIONS_ENABLED=true
RAG_ADMIN_ENABLED=false
RAG_CUSTOMER_ENABLED=false
RAG_GUEST_ENABLED=false

POSTGRES_RAG_IMAGE=pgvector/pgvector:pg16
POSTGRES_RAG_USER=postgres
POSTGRES_RAG_PASSWORD=postgres
POSTGRES_RAG_DB=fashion_rag_dev_db
POSTGRES_RAG_PORT=15433

# --- MinIO / S3-compatible local storage ---
MINIO_IMAGE=minio/minio:latest
# Host ports (9000/9001 often busy locally); inside Docker network MinIO stays on 9000
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=fashion-dev-uploads
MINIO_PRIVATE_BUCKET_NAME=fashion-dev-private
MINIO_PUBLIC_URL=http://localhost:19000/fashion-dev-uploads

# --- Security / auth (dev only defaults) ---
NODE_ENV=development
ENCRYPTION_KEY=dev-encryption-key-change-me-32chars
JWT_SECRET=dev-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Seed admin accounts ---
SUPER_ADMIN_EMAIL=superadmin@fashion.local
SUPER_ADMIN_PASSWORD=SuperAdmin123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@fashion.local
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
RESET_ADMIN_PASSWORDS=false

# --- Files / limits ---
MAX_FILE_SIZE=20971520
UPLOAD_DIR=./uploads

# --- Dev convenience ---
API_RATE_LIMIT_DISABLED=true
AUTH_RATE_LIMIT_DISABLED=true
BOT_PROTECTION_FAIL_CLOSED_IN_PRODUCTION=true
CAPTCHA_ENABLED_IN_PRODUCTION=true
CAPTCHA_PROVIDER=CLOUDFLARE_TURNSTILE
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
CAPTCHA_THRESHOLD=0.5
CAPTCHA_REQUIRE_FOR_REGISTRATION_IN_PRODUCTION=true
CAPTCHA_REQUIRE_FOR_LOGIN_IN_PRODUCTION=true
API_RATE_LIMIT_MAX=500
API_RATE_LIMIT_WINDOW_MINUTES=15
CHECKOUT_RATE_LIMIT_MAX=20
CHECKOUT_RATE_LIMIT_WINDOW_MINUTES=15
SEARCH_RATE_LIMIT_MAX=120
SEARCH_RATE_LIMIT_WINDOW_MINUTES=15
UPLOAD_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=15
REQUIRE_ADMIN_TWO_FACTOR_IN_PRODUCTION=true
MAX_ACTIVE_SESSIONS_PER_USER=5
