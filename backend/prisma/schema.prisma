// Payment Request (for bank transfer, P2P, and cash-on-delivery orders)
model PaymentRequest {
  id                    String    @id @default(uuid())
  orderId               String    @unique
  status                String    @default("PENDING") // "PENDING" | "PAID" | "CANCELLED"
  bankDetails           Json? // Bank account details for payment
  p2pDetails            Json? // P2P payment details (cardNumber, cryptoWallet, blockchain, sbpPhone, instruction)
  cashOnDeliveryDetails Json? // Cash on delivery: { instruction } — shown to customer
  paymentProof  String? // URL to payment proof document
  adminNotes    String?   @db.Text
  logisticsInfo Json? // Shipping/tracking information
  notifiedAt    DateTime? // When payment request was sent to customer
  paidAt        DateTime?
  shippedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  updatedBy     String? // Admin user ID

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("payment_requests")
}

// Return Request
enum ReturnReason {
  PRODUCT_NOT_DELIVERED // Product not delivered
  CUSTOMER_NOT_RECEIVED // Customer did not receive delivery
  CUSTOMER_REQUESTED // Customer requested return
}

enum ReturnStatus {
  REQUESTED // Requested by customer
  APPROVED // Approved by admin
  REJECTED // Rejected by admin
  PROCESSING // In progress
  COMPLETED // Completed
}

enum ReturnItemStatus {
  WRITE_OFF // Write off
  RETURN_TO_SALE // Return to sale
}

enum RefundMethod {
  STRIPE // Refund via Stripe
  BANK_TRANSFER // Bank transfer refund
  MANUAL // Manual refund
}

enum PickupMethod {
  COURIER // Courier pickup
  POST // Postal return
  PICKUP // Self pickup
}

model ReturnRequest {
  id                String        @id @default(uuid())
  orderId           String
  userId            String
  reason            ReturnReason
  status            ReturnStatus  @default(REQUESTED)
  refundMethod      RefundMethod?
  refundAmount      Decimal?      @db.Decimal(10, 2)
  refundProcessedAt DateTime?
  pickupMethod      PickupMethod? // Return pickup method
  pickupAddress     String?       @db.Text // Return address (courier or post)
  pickupDate        DateTime? // Return pickup date
  pickupNotes       String?       @db.Text // Additional return instructions
  adminNotes        String?       @db.Text
  customerNotes     String?       @db.Text
  processedBy       String? // Admin user ID
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order         Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         ReturnRequestItem[]
  statusHistory ReturnRequestStatusHistory[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("return_requests")
}

model ReturnRequestStatusHistory {
  id              String       @id @default(uuid())
  returnRequestId String
  status          ReturnStatus
  notes           String?      @db.Text
  changedBy       String? // Admin user ID
  createdAt       DateTime     @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@map("return_request_status_history")
}

model ReturnRequestItem {
  id                   String           @id @default(uuid())
  returnRequestId      String
  orderItemId          String
  quantity             Int
  replacementProductId String? // Replacement product ID
  replacementVariantId String? // Replacement variant ID (if any)
  itemStatus           ReturnItemStatus @default(WRITE_OFF) // Write off or return to sale
  warehouseId          String? // Warehouse for return
  notes                String?          @db.Text
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  warehouse     Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@index([orderItemId])
  @@index([warehouseId])
  @@map("return_request_items")
}

// Messenger Contact (for customer communication)
model MessengerContact {
  id        String   @id @default(uuid())
  userId    String
  type      String // "TELEGRAM" | "WHATSAPP" | "VIBER" | etc.
  contactId String // Telegram ID, WhatsApp number, etc.
  username  String? // Username or display name
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, contactId])
  @@index([userId])
  @@index([type])
  @@map("messenger_contacts")
}

// Currency Exchange Rates
model CurrencyRate {
  id        String   @id @default(uuid())
  currency  String   @unique // Currency code (e.g., "USD", "EUR", "RUB")
  rateToUsd Decimal  @db.Decimal(10, 6) // Exchange rate to USD (1 USD = rateToUsd * currency)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
  updatedBy String? // Admin user ID

  @@index([currency])
  @@index([isActive])
  @@map("currency_rates")
}

// Currency rate auto-update API settings (single row)
model CurrencyRateSettings {
  id                String   @id @default(uuid())
  provider          String   @default("EXCHANGERATE_API") // EXCHANGERATE_API | FIXER | OPEN_EXCHANGE_RATES
  apiKey            String?  @db.Text // API key (stored server-side only)
  baseUrl           String?  @db.Text // Optional override URL
  autoUpdateEnabled Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String? // Admin user ID

  @@map("currency_rate_settings")
}

// Partner Commissions
model PartnerCommission {
  id               String   @id @default(uuid())
  partnerId        String // Partner who gets the commission
  orderId          String // Order that generated the commission
  promoCodeId      String // Promo code used
  orderTotal       Decimal  @db.Decimal(10, 2) // Order total at the time of commission creation
  commissionRate   Decimal  @db.Decimal(5, 2) // Commission rate (e.g., 10.00 for 10%)
  commissionAmount Decimal  @db.Decimal(10, 2) // Calculated commission amount
  status           String // "PENDING" | "PAID" | "CANCELLED"
  payoutId         String? // Payout this commission is included in (nullable)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  partner   User           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promoCode PromoCode      @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  payout    PartnerPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([partnerId])
  @@index([orderId])
  @@index([promoCodeId])
  @@index([status])
  @@index([payoutId])
  @@index([createdAt])
  @@map("partner_commissions")
}

// Partner Payouts
model PartnerPayout {
  id              String    @id @default(uuid())
  partnerId       String // Partner requesting the payout
  amount          Decimal   @db.Decimal(10, 2) // Payout amount
  status          String // "PENDING" | "APPROVED" | "PAID" | "REJECTED"
  requestedAt     DateTime  @default(now()) // When partner requested the payout
  approvedAt      DateTime? // When admin approved the payout
  paidAt          DateTime? // When payout was marked as paid
  rejectionReason String?   @db.Text // Reason for rejection (if rejected)
  adminNotes      String?   @db.Text // Admin notes
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  partner     User                @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  commissions PartnerCommission[] // Commissions included in this payout

  @@index([partnerId])
  @@index([status])
  @@index([requestedAt])
  @@map("partner_payouts")
}

// Partner Documents (Agency contracts, etc.)
model PartnerDocument {
  id          String    @id @default(uuid())
  partnerId   String // Partner this document belongs to
  name        String // Document name (e.g., "Agency Contract")
  type        String // Document type: "CONTRACT" | "AGREEMENT" | "OTHER"
  fileUrl     String // URL to the document file
  fileName    String // Original file name
  fileSize    Int? // File size in bytes
  mimeType    String? // MIME type
  description String?   @db.Text // Document description
  expiresAt   DateTime? // Expiration date (if applicable)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  partner User @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([type])
  @@index([createdAt])
  @@map("partner_documents")
}

// License Management (Self-Hosted Enterprise)
// Blog
enum BlogPostType {
  ARTICLE
  VIDEO
  MIXED
}

enum BlogMediaFormat {
  AUTO
  LANDSCAPE
  PORTRAIT
  SQUARE
}

enum BlogLayoutStyle {
  MAGAZINE // Magazine layout
  INSTAGRAM // Instagram layout
  TIKTOK // TikTok layout
  MIXED // Adaptive mixed media feed
}

model BlogPost {
  id                String       @id @default(uuid())
  slug              String       @unique
  title             String
  excerpt           String?      @db.Text
  content           String?      @db.Text // HTML content for articles
  videoUrl          String? // Video URL for video posts
  thumbnailUrl      String? // Thumbnail image URL
  type              BlogPostType @default(ARTICLE)
  displayFormat     BlogMediaFormat @default(AUTO)
  categoryId        String?
  blogAuthorId      String?
  isPublished       Boolean      @default(false)
  publishedAt       DateTime?
  authorId          String? // Admin user ID
  views             Int          @default(0)
  metaTitle         String?
  metaDescription   String?      @db.Text
  faqItems          Json?
  tags              String[] // Array of tags
  linkedProductIds  String[]     @default([]) // Product IDs for "buy" previews (image + link)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  author             User?                 @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  category           BlogCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  blogAuthor         BlogAuthor?           @relation(fields: [blogAuthorId], references: [id], onDelete: SetNull)
  translations       BlogPostTranslation[]
  featuredInSettings BlogSettings[]        @relation("FeaturedBlogPost")

  @@index([slug])
  @@index([type])
  @@index([displayFormat])
  @@index([categoryId])
  @@index([blogAuthorId])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([authorId])
  @@index([createdAt])
  @@map("blog_posts")
}

model BlogAuthor {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  bio         String?  @db.Text
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts BlogPost[]

  @@index([slug])
  @@map("blog_authors")
}

model BlogCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]

  @@index([slug])
  @@map("blog_categories")
}

model BlogPostTranslation {
  id              String   @id @default(uuid())
  blogPostId      String
  languageCode    String // ISO 639-1 (e.g., "en", "ru")
  title           String?
  excerpt         String?  @db.Text
  content         String?  @db.Text
  metaTitle       String?
  metaDescription String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  blogPost BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, languageCode])
  @@index([blogPostId])
  @@index([languageCode])
  @@map("blog_post_translations")
}

model BlogSettings {
  id               String          @id @default(uuid())
  layoutStyle      BlogLayoutStyle @default(MAGAZINE) // MAGAZINE, INSTAGRAM, TIKTOK
  gridColumns      String          @default("grid-cols-1 md:grid-cols-2 lg:grid-cols-3") // Tailwind grid classes
  gap              String          @default("gap-4") // Tailwind gap classes
  itemsPerPage     Int             @default(12)
  showExcerpt      Boolean         @default(true)
  showAuthor       Boolean         @default(true)
  showDate         Boolean         @default(true)
  showViews        Boolean         @default(false)
  showTags         Boolean         @default(true)
  // Header settings
  headerTitle      String?         @db.Text
  headerSubtitle   String?         @db.Text
  headerImageUrl   String?
  headerVideoUrl   String?
  heroFullscreen   Boolean         @default(false)
  heroHeight       String          @default("70vh")
  heroAutoZoom     Boolean         @default(true)
  // Typography
  titleFontSize    String          @default("text-2xl")
  excerptFontSize  String          @default("text-base")
  // Colors
  backgroundColor  String          @default("#ffffff")
  textColor        String          @default("#000000")
  accentColor      String          @default("#000000")
  // Spacing
  paddingTop       String          @default("py-8")
  paddingBottom    String          @default("py-8")
  // Card styling
  cardBorderRadius String          @default("rounded-lg")
  cardShadow       Boolean         @default(true)
  cardHoverEffect  Boolean         @default(true)
  // Magazine layout specific
  featuredPostId   String? // ID of featured post for magazine layout
  // Instagram layout specific
  aspectRatio      String          @default("aspect-square") // aspect-square, aspect-video, etc.
  // TikTok layout specific
  videoAutoplay    Boolean         @default(true)
  videoLoop        Boolean         @default(true)
  videoMuted       Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  updatedBy        String? // Admin user ID

  featuredPost BlogPost? @relation("FeaturedBlogPost", fields: [featuredPostId], references: [id], onDelete: SetNull)

  translations BlogSettingsTranslation[]

  @@map("blog_settings")
}

model BlogSettingsTranslation {
  id             String   @id @default(uuid())
  blogSettingsId String
  languageCode   String // ISO 639-1 (e.g., "en", "ru")
  headerTitle    String?  @db.Text
  headerSubtitle String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blogSettings BlogSettings @relation(fields: [blogSettingsId], references: [id], onDelete: Cascade)

  @@unique([blogSettingsId, languageCode])
  @@index([blogSettingsId])
  @@index([languageCode])
  @@map("blog_settings_translations")
}

// API Keys for external integrations
model ApiKey {
  id             String    @id @default(uuid())
  key            String    @unique // Hashed API key
  keyPrefix      String // First 8 chars for display (e.g., "sk_live_")
  name           String // User-friendly name
  description    String? // Optional description
  userId         String // Owner (Admin who created it)
  allowedIPs     String[] // Array of allowed IP addresses (empty = all IPs)
  allowedDomains String[] // Array of allowed domains (empty = all domains)
  scopes         String[] // Array of API scopes (empty = full access)
  // Scopes format: "resource:action" (e.g., "products:read", "orders:write", "admin:*")
  // Available scopes:
  // - products:read, products:write
  // - categories:read, categories:write
  // - brands:read, brands:write
  // - cart:read, cart:write
  // - orders:read, orders:write
  // - customers:read, customers:write
  // - reviews:read, reviews:write
  // - promo:read, promo:write
  // - loyalty:read, loyalty:write
  // - homepage:read, homepage:write
  // - pages:read, pages:write
  // - lookbook:read, lookbook:write
  // - blog:read, blog:write
  // - settings:read, settings:write
  // - countries:read, countries:write
  // - languages:read, languages:write
  // - currency-rates:read, currency-rates:write
  // - payment-gateways:read, payment-gateways:write
  // - payment-requests:read, payment-requests:write
  // - admin:* (full admin access)
  // - reports:read
  // - partner:read, partner:write
  // - delivery-tracking:read, delivery-tracking:write
  // - messenger:read, messenger:write
  // - translations:read, translations:write
  // - header:read, header:write
  // - footer:read, footer:write
  // - backups:read, backups:write
  rateLimit      Int       @default(1000000000) // Requests per 15 min (1e9 = effectively off)
  quota          Int? // Total requests quota (null = unlimited)
  quotaUsed      Int       @default(0) // Current usage
  expiresAt      DateTime? // Expiration date (null = never expires)
  lastUsedAt     DateTime? // Last time the key was used
  lastUsedIP     String? // Last IP that used the key
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs ApiKeyUsageLog[]

  @@index([userId])
  @@index([keyPrefix])
  @@index([isActive])
  @@index([expiresAt])
  @@map("api_keys")
}

// API Key usage logs for monitoring and analytics
model ApiKeyUsageLog {
  id           String   @id @default(uuid())
  apiKeyId     String
  ip           String
  endpoint     String // API endpoint that was called
  method       String // HTTP method
  statusCode   Int // Response status code
  responseTime Int // Response time in ms
  createdAt    DateTime @default(now())

  // Relations
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([createdAt])
  @@index([ip])
  @@map("api_key_usage_logs")
}

// GPT Assistant Settings
model GPTAssistantSettings {
  id              String  @id @default(uuid())
  // General settings
  enabledAdmin    Boolean @default(true)
  enabledCustomer Boolean @default(true)
  enabledGuest    Boolean @default(false)
  mode            String  @default("production") // "production" | "test" | "disabled"
  logLevel        String  @default("info") // "error" | "warn" | "info" | "debug"

  // Display (customizable in admin)
  displayTitle String? // Custom title in chat header (e.g. "GPT" or "Support")
  fabIconUrl   String? // URL of custom icon for floating button (image); if empty, default SVG is used

  // API provider
  providerType  String  @default("openai") // "openai" | "anthropic" | "custom" | "lm_studio"
  model         String  @default("gpt-4")
  apiBaseUrl    String? // OpenAI-compatible base URL, e.g. http://127.0.0.1:1234/v1 (LM Studio, proxy)
  apiKey        String? @db.Text // Encrypted
  testApiKey    String? @db.Text // Encrypted
  maxTokens     Int     @default(2000)
  temperature   Decimal @default(0.7) @db.Decimal(3, 2)
  contextWindow Int     @default(10)
  timeout       Int     @default(30000) // milliseconds

  // Behavior for admins
  adminMaxResponseLength  Int     @default(2000)
  adminEnableSuggestions  Boolean @default(true)
  adminEnableQuickActions Boolean @default(true)
  adminDetailLevel        String  @default("detailed") // "detailed" | "normal" | "brief"

  // Behavior for customers
  customerMaxResponseLength     Int     @default(1500)
  customerEnableSuggestions     Boolean @default(true)
  customerEnableQuickActions    Boolean @default(true)
  customerTone                  String  @default("friendly") // "friendly" | "professional" | "casual"
  customerEnableRecommendations Boolean @default(true)
  customerEnableContextHelp     Boolean @default(true)

  // Rate Limiting (1e9 = effectively off)
  rateLimitAdmin       Int     @default(1000000000)
  rateLimitCustomer    Int     @default(1000000000)
  rateLimitGuest       Int     @default(1000000000)
  blockOnLimitExceeded Boolean @default(true)

  // Security
  filterContent    Boolean @default(true)
  checkPermissions Boolean @default(true)
  logAllRequests   Boolean @default(true)
  anonymizeLogs    Boolean @default(false)

  // Caching
  enableCache          Boolean @default(true)
  cacheTTL             Int     @default(3600) // seconds
  cacheFrequentQueries Boolean @default(true)
  maxCacheSize         Int     @default(100) // MB

  // Speech-to-text: none | browser | openai | custom (server STT later)
  sttProvider String @default("none")

  // RAG
  ragEnabled        Boolean @default(false)
  ragEmbeddingModel String  @default("text-embedding-3-large")

  updatedAt DateTime @updatedAt
  updatedBy String? // Admin user ID

  @@map("gpt_assistant_settings")
}

// GPT Assistant Prompts
model GPTAssistantPrompt {
  id        String   @id @default(uuid())
  type      String // "admin" | "customer" | "quick_admin" | "quick_customer" | "admin_intent_recognition" | "customer_intent_recognition"
  prompt    String   @db.Text
  version   String   @default("1.0")
  comment   String?  @db.Text
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0) // For quick_admin/quick_customer: order of buttons in chat
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // Admin user ID

  @@unique([type, version])
  @@index([type])
  @@index([isActive])
  @@map("gpt_assistant_prompts")
}

// Admin Assistant Chat History
model AdminAssistantChatHistory {
  id            String   @id @default(uuid())
  adminId       String
  message       String   @db.Text
  response      String   @db.Text
  intent        String
  data          Json?
  executionTime Int // milliseconds
  createdAt     DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([intent])
  @@index([createdAt])
  @@map("admin_assistant_chat_history")
}

// Customer Assistant Chat History
model CustomerAssistantChatHistory {
  id            String   @id @default(uuid())
  userId        String? // null for guests
  sessionId     String? // for guests
  message       String   @db.Text
  response      String   @db.Text
  intent        String
  data          Json?
  executionTime Int // milliseconds
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([intent])
  @@index([createdAt])
  @@map("customer_assistant_chat_history")
}

model AiConversation {
  id              String               @id @default(uuid())
  channel         AiConversationChannel
  status          AiConversationStatus @default(OPEN)
  adminId         String?
  userId          String?
  guestSessionId  String?
  title           String?
  language        String?
  topicLabel      String?
  summary         String?              @db.Text
  lastIntent      String?
  lastMessageAt   DateTime             @default(now())
  resolvedAt      DateTime?
  escalatedAt     DateTime?
  assignedAdminId String?
  supportTicketId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  admin      User?                 @relation("AdminAiConversations", fields: [adminId], references: [id], onDelete: Cascade)
  customer   User?                 @relation("CustomerAiConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages   AiConversationMessage[]
  executions AiActionExecution[]

  @@index([channel, status, lastMessageAt])
  @@index([userId, createdAt])
  @@index([adminId, createdAt])
  @@index([topicLabel, createdAt])
  @@index([supportTicketId])
  @@map("ai_conversations")
}

model AiConversationMessage {
  id                String        @id @default(uuid())
  conversationId    String
  role              AiMessageRole
  actorUserId       String?
  content           String        @db.Text
  translatedContent String?       @db.Text
  intent            String?
  toolData          Json?
  isError           Boolean       @default(false)
  createdAt         DateTime      @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([intent])
  @@map("ai_conversation_messages")
}

model AiActionExecution {
  id                   String            @id @default(uuid())
  conversationId       String
  messageId            String?
  actionId             String
  status               AiExecutionStatus
  permissionChecked    Boolean           @default(false)
  confirmationRequired Boolean           @default(false)
  arguments            Json
  previewData          Json?
  resultData           Json?
  errorCode            String?
  errorMessage         String?           @db.Text
  createdAt            DateTime          @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([actionId, status, createdAt])
  @@map("ai_action_executions")
}
