  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  updatedBy                String? // Admin user ID

  @@map("header_settings")
}

// Country Settings
model Country {
  id                    String   @id @default(uuid())
  code                  String   @unique // ISO 3166-1 alpha-2 (e.g., "US", "RU")
  name                  String
  nameNative            String? // Native name
  currency              String // Currency code (e.g., "USD", "RUB")
  language              String // Default language code (e.g., "en", "ru")
