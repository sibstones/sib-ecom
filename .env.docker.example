# Docker / production template. Copy to `.env` and fill in secrets locally.
# Do not commit real values.
# cp .env.docker.example .env

# --- Runtime / containers ---
NODE_ENV=production
PORT=3001
FRONTEND_PORT=8080

# --- Frontend ---
FRONTEND_BASE_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
PUBLIC_SITE_URL=https://your-domain.com
VITE_API_URL=/api
# Bump this value when you want to force a clean Docker rebuild on redeploy.
CACHE_BUST=0
# Helps frontend build avoid heap out of memory during Vite/SvelteKit compile.
NODE_OPTIONS=--max-old-space-size=3072

# --- Backend ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fashion_db?schema=public
RAG_ENABLED=false
RAG_DATABASE_URL=postgresql://postgres:postgres@postgres-rag:5432/fashion_rag_db?schema=public
RAG_DATABASE_DIRECT_URL=postgresql://postgres:postgres@postgres-rag:5432/fashion_rag_db?schema=public
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_RETRIEVAL_TOP_K=8
RAG_RETRIEVAL_MIN_SCORE=0.2
RAG_HYBRID_SEARCH_ENABLED=true
RAG_RERANK_ENABLED=false
RAG_CITATIONS_ENABLED=true
RAG_ADMIN_ENABLED=false
RAG_CUSTOMER_ENABLED=false
RAG_GUEST_ENABLED=false

# Encrypt sensitive DB fields.
# Generate with: openssl rand -base64 32
# Leaving it empty is only acceptable for development.
ENCRYPTION_KEY=

# JWT defaults for Docker / staging.
# Replace with your own secrets in production (32+ characters recommended).
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Default admin accounts created on first startup.
# In production, change passwords and email addresses.
SUPER_ADMIN_EMAIL=superadmin@fashion.com
SUPER_ADMIN_PASSWORD=SuperAdmin123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@fashion.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
RESET_ADMIN_PASSWORDS=false

# --- S3 / object storage ---
# Example values below target an external S3-compatible provider.
# If you use the internal Docker MinIO service instead, use its internal host/port.
MINIO_ENDPOINT=s3.test.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_REGION=ru-1
MINIO_ACCESS_KEY=YOUR_S3_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_S3_SECRET_KEY
MINIO_BUCKET_NAME=your-project-uploads
MINIO_PRIVATE_BUCKET_NAME=your-project-private
MINIO_PUBLIC_URL=https://s3.test.com/your-project-uploads

# --- Upload / API ---
MAX_FILE_SIZE=20971520
UPLOAD_DIR=./uploads

# Optional local RAG Postgres with pgvector
POSTGRES_RAG_IMAGE=pgvector/pgvector:pg16
POSTGRES_RAG_USER=postgres
POSTGRES_RAG_PASSWORD=postgres
POSTGRES_RAG_DB=fashion_rag_db
POSTGRES_RAG_PORT=5434

# Global `/api` rate limit defaults for production
API_RATE_LIMIT_DISABLED=false
API_RATE_LIMIT_MAX=500
API_RATE_LIMIT_WINDOW_MINUTES=15
CHECKOUT_RATE_LIMIT_MAX=20
CHECKOUT_RATE_LIMIT_WINDOW_MINUTES=15
SEARCH_RATE_LIMIT_MAX=120
SEARCH_RATE_LIMIT_WINDOW_MINUTES=15
UPLOAD_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=15

# CAPTCHA / bot protection production defaults
BOT_PROTECTION_FAIL_CLOSED_IN_PRODUCTION=true
CAPTCHA_ENABLED_IN_PRODUCTION=true
CAPTCHA_PROVIDER=CLOUDFLARE_TURNSTILE
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
CAPTCHA_THRESHOLD=0.5
CAPTCHA_REQUIRE_FOR_REGISTRATION_IN_PRODUCTION=true
CAPTCHA_REQUIRE_FOR_LOGIN_IN_PRODUCTION=true
REQUIRE_ADMIN_TWO_FACTOR_IN_PRODUCTION=true
MAX_ACTIVE_SESSIONS_PER_USER=5

# BACKUP_DIR=./backend/backups
