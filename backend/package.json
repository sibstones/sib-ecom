{
  "name": "fashion-backend",
  "version": "1.0.0",
  "description": "Fashion e-commerce backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:with-migrate": "prisma migrate deploy && node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:rag": "prisma generate --schema prisma-rag/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:rag": "prisma migrate dev --schema prisma-rag/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:deploy:rag": "prisma migrate deploy --schema prisma-rag/schema.prisma",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate reset --force",
    "wait:db": "tsx src/scripts/wait-for-db.ts",
    "verify:migrations": "node scripts/verify-migrations.js",
    "init:admins": "tsx src/scripts/init-admins.ts",
    "reset:admins": "RESET_ADMIN_PASSWORDS=true tsx src/scripts/init-admins.ts",
    "init:gpt-assistant": "tsx src/scripts/init-gpt-assistant-settings.ts",
    "init:gpt-assistant-prompts": "tsx src/scripts/init-gpt-assistant-prompts.ts",
    "seed:dev-showcase": "tsx src/scripts/seed-dev-showcase.ts",
    "seed:ai-conversations": "tsx src/scripts/seed-ai-conversations.ts",
    "init:countries-languages": "tsx src/scripts/init-default-countries-languages.ts",
    "check:admins": "tsx src/scripts/check-admins.ts",
    "reset:inventory": "tsx src/scripts/reset-inventory.ts",
    "reset:orders": "tsx src/scripts/reset-orders-tickets-payments.ts",
    "reset:all": "tsx src/scripts/reset-all.ts",
    "backup:db": "tsx src/scripts/backup-db.ts",
    "restore:db": "tsx src/scripts/restore-db.ts",
    "list:backups": "tsx src/scripts/list-backups.ts",
    "backup:db-docker": "tsx src/scripts/backup-db-docker.ts",
    "restore:db-docker": "tsx src/scripts/restore-db-docker.ts",
    "backup:s3": "tsx src/scripts/backup-s3.ts",
    "restore:s3": "tsx src/scripts/restore-s3.ts",
    "list:s3-backups": "tsx src/scripts/list-s3-backups.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --config jest.unit.config.js",
    "test:yookassa": "tsx src/scripts/test-yookassa.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "fashion",
    "e-commerce",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.700.0",
    "@prisma/client": "^5.22.0",
    "alipay-sdk": "^4.14.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^7.1.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "openai": "^4.104.0",
    "otplib": "^13.4.0",
    "prisma": "^5.7.1",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "stripe": "^20.2.0",
    "tar": "^7.4.3",
    "tsx": "^4.7.0",
    "uuid": "^9.0.1",
    "wechatpay-node-v3": "^2.2.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  }
}
