// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  RETURN_REQUESTED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderSource {
  STORE_ONLINE
  STORE_OFFLINE
  MARKETPLACE_WB
  MARKETPLACE_OZON
  MARKETPLACE_WILDBERRIES
  MARKETPLACE_OTHER
  MANUAL
}

enum SalesPointType {
  MARKETPLACE
  STORE_OFFLINE
}

enum WarehouseType {
  MAIN
  STORE
  MARKETPLACE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AiConversationChannel {
  ADMIN
  CUSTOMER
}

enum AiConversationStatus {
  OPEN
  WAITING_FOR_USER
  WAITING_FOR_ADMIN
  RESOLVED
  FAILED
  ESCALATED
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
  OPERATOR_NOTE
}

enum AiExecutionStatus {
  PARSED
  PREVIEWED
  CONFIRMED
  EXECUTED
  NOOP
  FAILED
  REJECTED
}

enum SupportTicketSource {
  MANUAL
  AI_CUSTOMER
  AI_ADMIN
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketMessageSource {
  CUSTOMER
  ADMIN
  AI_DRAFT
  AI_SENT
}

enum ProductType {
  CLOTHING
  SHOES
  CUSTOM
  VOLUME   // volume in ml
  WEIGHT   // weight in g
}

enum InventoryStatus {
  AWAITING_RECEIPT // Awaiting stock
  RECEIVED // Received at warehouse
  IN_SALE // In sale
  COMING_SOON // Visible on storefront, but not available for purchase yet
  RESERVED // Reserved for order
  IN_DELIVERY // In delivery to customer
  DELIVERED // Delivered to customer
  RETURNED // Returned
  OUT_OF_STOCK // Out of stock
}

// Users & Auth
model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String? // Optional for OAuth users
  firstName          String?
  lastName           String?
  phone              String?
  role               UserRole @default(CUSTOMER)
  preferredLanguage  String? // ISO 639-1 (e.g. "en", "ru") — saved when user changes language on frontend
  emailVerified      Boolean  @default(false)
  /// TOTP (Google Authenticator, etc.); secret stored encrypted at rest
  twoFactorEnabled       Boolean  @default(false)
  twoFactorSecret        String?  @db.Text
  twoFactorPendingSecret String?  @db.Text // During setup until first code is confirmed
  isActive           Boolean  @default(true) // For deactivating admins/moderators
  isPartner          Boolean  @default(false) // Partner status
  partnerStatus      String? // "ACTIVE" | "INACTIVE" | "SUSPENDED"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  addresses                    CustomerAddress[]
  orders                       Order[]
  wishlistItems                WishlistItem[]
  cartItems                    CartItem[]
  sessions                     Session[]
  passwordResetTokens          PasswordResetToken[]
  emailVerificationTokens      EmailVerificationToken[]
  failedLoginAttempts          FailedLoginAttempt[]
  reviews                      ProductReview[]
  loyaltyPoints                LoyaltyPoints?
  messengerContacts            MessengerContact[]
  tickets                      SupportTicket[]
  adminPermissions             AdminPermissions?
  activityLogs                 AdminActivityLog[]
  createdAdminLogs             AdminActivityLog[]             @relation("CreatedByAdmin")
  returnRequests               ReturnRequest[]
  promoCodes                   PromoCode[]
  partnerPromoCodes            PromoCode[]                    @relation("PartnerPromoCodes")
  partnerCommissions           PartnerCommission[]
  partnerPayouts               PartnerPayout[]
  partnerDocuments             PartnerDocument[]
  blogPosts                    BlogPost[]                     @relation("BlogAuthor")
  apiKeys                      ApiKey[]
  oauthAccounts                OAuthAccount[]
  adminAssistantChatHistory    AdminAssistantChatHistory[]
  customerAssistantChatHistory CustomerAssistantChatHistory[]
  adminAiConversations         AiConversation[]               @relation("AdminAiConversations")
  customerAiConversations      AiConversation[]               @relation("CustomerAiConversations")

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([isPartner])
  @@index([partnerStatus])
  @@map("users")
}

// OAuth Accounts
model OAuthAccount {
  id           String    @id @default(uuid())
  userId       String
  provider     String // "GOOGLE" | "YANDEX" | "VKONTAKTE" | "FACEBOOK" | "APPLE"
  providerId   String // Unique ID from OAuth provider
  email        String? // Email from OAuth provider
  firstName    String?
  lastName     String?
  avatarUrl    String?
  accessToken  String?   @db.Text // Encrypted access token
  refreshToken String?   @db.Text // Encrypted refresh token
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@index([providerId])
  @@map("oauth_accounts")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model FailedLoginAttempt {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("failed_login_attempts")
}

// Products
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  isMain      Boolean  @default(false) // Main category (Men/Women etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent       Category?             @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]            @relation("CategoryTree")
  products     Product[]
  translations CategoryTranslation[]

  @@index([slug])
  @@index([isMain])
  @@index([parentId])
  @@map("categories")
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@map("brands")
}

model Product {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  description         String?  @db.Text
  sku                 String   @unique
  price               Decimal? @db.Decimal(10, 2) // Nullable for price on request
  compareAtPrice      Decimal? @db.Decimal(10, 2)
  priceOnRequest      Boolean  @default(false) // If true, price is not set and customer needs to request it
  categoryId          String
  brandId             String?
  isActive            Boolean  @default(true)
  isFeatured          Boolean  @default(false)
  // Product type and sizes
  productType         Json? // Array of ProductType values: ["CLOTHING", "SHOES", "CUSTOM", "VOLUME", "WEIGHT"] - can be combined
  sizes               Json? // Object with sizes per type: { "CLOTHING": ["XS", "S", "M"], "SHOES": ["38", "39"], "CUSTOM": [{value: "50", label: "50cm"}], "VOLUME": ["50", "100"], "WEIGHT": ["100", "200"] }
  // Filter attributes
  color               Json? // Array of { name: string, hex: string } objects
  material            String?  // Composition
  lining              String?
  application         String?  @db.Text // Application / (optional)
  countryOfOrigin     String?
  // Visibility flags for public page
  hideColor           Boolean  @default(false)
  hideMaterial        Boolean  @default(false)
  hideLining          Boolean  @default(false)
  hideCountryOfOrigin Boolean  @default(false)
  // Complete the look - related products recommendations
  relatedProducts     Json? // Array of product IDs: ["uuid1", "uuid2", ...]
  showCompleteTheLook Boolean  @default(true) // Show/hide "Complete the Look" section on product page
  // SEO fields - not visible on product page but used for search engines
  metaTitle           String? // SEO title for search engines
  metaDescription     String?  @db.Text // SEO description for search engines
  metaKeywords        String?  @db.Text // SEO keywords for search engines
  // Admin-only: accounting & customs (Delivery by Seller reports)
  costPrice             Decimal?  @db.Decimal(10, 2)
  costCurrency          String?   // ISO 4217
  customsCode           String?   // TN VED / HS code
  vatRate               Decimal?  @db.Decimal(5, 4) // e.g. 0.20 = 20%
  exciseGoods           Boolean   @default(false)
  importDeclarationNumber String?
  importDeclarationDate   DateTime?
  customsValue          Decimal?  @db.Decimal(10, 2)
  customsValueCurrency   String?
  weightNet             Decimal?  @db.Decimal(10, 4) // kg, per unit (for shipping)
  weightGross           Decimal?  @db.Decimal(10, 4) // kg, per unit (for shipping)
  lengthCm              Decimal?  @db.Decimal(10, 2) // cm, per unit (for shipping)
  widthCm               Decimal?  @db.Decimal(10, 2) // cm, per unit (for shipping)
  heightCm              Decimal?  @db.Decimal(10, 2) // cm, per unit (for shipping)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  category         Category             @relation(fields: [categoryId], references: [id])
  brand            Brand?               @relation(fields: [brandId], references: [id])
  images           ProductImage[]
  variants         ProductVariant[]
  inventory        Inventory[]
  orderItems       OrderItem[]
  wishlistItems    WishlistItem[]
  cartItems        CartItem[]
  lookbookTags     LookbookProductTag[]
  reviews          ProductReview[]
  translations     ProductTranslation[]
  salesPointProducts SalesPointProduct[]

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([productType])
  @@index([color])
  @@index([material])
  @@index([countryOfOrigin])
  @@map("products")
}

model ProductTranslation {
  id              String   @id @default(uuid())
  productId       String
  languageCode    String // ISO 639-1 (e.g., "en", "ru")
  name            String?
  description     String?  @db.Text
  material        String?
  lining          String?
  countryOfOrigin String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, languageCode])
  @@index([productId])
  @@index([languageCode])
  @@map("product_translations")
}

model CategoryTranslation {
  id           String   @id @default(uuid())
  categoryId   String
  languageCode String // ISO 639-1 (e.g., "en", "ru")
  name         String?
  description  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageCode])
  @@index([categoryId])
  @@index([languageCode])
  @@map("category_translations")
}

model PageTranslation {
  id              String   @id @default(uuid())
  pageId          String
  languageCode    String // ISO 639-1 (e.g., "en", "ru")
  title           String?
  content         String?  @db.Text
  metaTitle       String?
  metaDescription String?  @db.Text
  config          Json? // For translated config fields (buttonText, description, etc.)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, languageCode])
  @@index([pageId])
  @@index([languageCode])
  @@map("page_translations")
}

model HomepageSectionTranslation {
  id           String   @id @default(uuid())
  sectionId    String
  languageCode String // ISO 639-1 (e.g., "en", "ru")
  title        String?
  config       Json? // Translated config fields (buttonText, description, etc.)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  section HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, languageCode])
  @@index([sectionId])
  @@index([languageCode])
  @@map("homepage_section_translations")
}

model LookbookTranslation {
  id           String   @id @default(uuid())
  lookbookId   String
  languageCode String // ISO 639-1 (e.g., "en", "ru")
  title        String?
  description  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lookbook Lookbook @relation(fields: [lookbookId], references: [id], onDelete: Cascade)

  @@unique([lookbookId, languageCode])
  @@index([lookbookId])
  @@index([languageCode])
  @@map("lookbook_translations")
}

model ProductPageDesignTranslation {
  id              String   @id @default(uuid())
  languageCode    String   @unique // ISO 639-1 (e.g., "en", "ru") - only one translation per language for global settings
  sizeChartLabels Json? // Object mapping original labels to translated labels: { "ITALY": "Italy", "UK": "United Kingdom", ... }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([languageCode])
  @@map("product_page_design_translations")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  name          String // e.g., "Size: M, Color: Black"
  sku           String   @unique
  price         Decimal? @db.Decimal(10, 2) // Override product price if set
  size          String? // Size for the variant (e.g., "XS", "S", "M", "38", "39")
  showOnProduct Boolean  @default(false) // Show variant on product page
  // Admin-only: override for reports
  costPrice     Decimal? @db.Decimal(10, 2)
  customsCode   String?
  vatRate       Decimal? @db.Decimal(5, 4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  Inventory[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  salesPointProducts SalesPointProduct[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

// Inventory
model Warehouse {
  id        String         @id @default(uuid())
  name      String
  address   String?
  city      String?
  country   String?
  type      WarehouseType  @default(MAIN)
  priority  Int            @default(0) @db.SmallInt
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  inventory          Inventory[]
  movements          InventoryMovement[]
  pallets            Pallet[]
  returnRequestItems ReturnRequestItem[]
  fulfillmentOrders  Order[]              @relation("OrderFulfillmentWarehouse")
  salesPoints        SalesPoint[]         // Points using this warehouse (STORE_OFFLINE)
  salesPointProducts SalesPointProduct[]  // Products allocated from this warehouse

  @@index([type])
  @@map("warehouses")
}

// Sales Points (marketplaces, offline stores)
model SalesPoint {
  id          String         @id @default(uuid())
  name        String
  type        SalesPointType
  isActive    Boolean        @default(true)
  warehouseId String?        // For STORE_OFFLINE: store's warehouse
  externalId  String?        // Platform ID (Ozon, WB)
  settings    Json?          // API keys, URLs (encrypted)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  warehouse Warehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  products  SalesPointProduct[]
  orders    Order[]

  @@index([type])
  @@index([warehouseId])
  @@map("sales_points")
}

model SalesPointProduct {
  id           String   @id @default(uuid())
  salesPointId String
  productId    String
  variantId    String?  // null = all variants
  warehouseId  String?  // Fulfillment warehouse (for marketplace)
  maxQuantity  Int?     // Max qty for sale (null = no limit)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesPoint SalesPoint      @relation(fields: [salesPointId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse  Warehouse?      @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@unique([salesPointId, productId, variantId])
  @@index([salesPointId])
  @@index([productId])
  @@map("sales_point_products")
}

model Pallet {
  id          String   @id @default(uuid())
  warehouseId String
  code        String // Unique pallet code (e.g. "A-01-001")
  location    String? // Warehouse location (e.g. "Section A, Row 1, Shelf 3")
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  items     InventoryItem[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@map("pallets")
}

model Inventory {
  id          String          @id @default(uuid())
  productId   String
  variantId   String?
  warehouseId String
  quantity    Int             @default(0)
  reserved    Int             @default(0)
  status      InventoryStatus @default(AWAITING_RECEIPT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  items     InventoryItem[]

  @@unique([productId, variantId, warehouseId])
  @@index([warehouseId])
  @@index([status])
  @@map("inventory")
}

model InventoryItem {
  id          String          @id @default(uuid())
  inventoryId String
  palletId    String?
  orderId     String? // Link to order when item is reserved/in delivery
  quantity    Int             @default(1)
  status      InventoryStatus @default(AWAITING_RECEIPT)
  notes       String?         @db.Text
  receivedAt  DateTime?       // Admin: actual receipt date
  batchNumber String?         // Admin: batch for traceability
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  inventory Inventory        @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  pallet    Pallet?          @relation(fields: [palletId], references: [id], onDelete: SetNull)
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  qrCodes   DeliveryQRCode[]

  @@index([inventoryId])
  @@index([palletId])
  @@index([orderId])
  @@index([status])
  @@map("inventory_items")
}

model DeliveryQRCode {
  id              String    @id @default(uuid())
  inventoryItemId String
  orderId         String? // Link to order for delivery
  code            String    @unique // QR code (UUID or custom format)
  qrImageUrl      String? // QR code image URL
  isUsed          Boolean   @default(false)
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId])
  @@index([orderId])
  @@index([code])
  @@index([isUsed])
  @@map("delivery_qr_codes")
}

model InventoryMovement {
  id                   String    @id @default(uuid())
  warehouseId          String
  productId            String
  variantId            String?
  quantity             Int
  type                 String    // "IN", "OUT", "TRANSFER"
  reason               String?
  // Admin-only: documents & supplier (reports)
  documentNumber       String?
  documentDate         DateTime?
  supplierName         String?
  supplierInn          String?
  supplierVatNumber    String?
  customsDeclarationId String?
  purchasePrice        Decimal?  @db.Decimal(10, 2)
  purchaseCurrency     String?
  receivedAt           DateTime? // Admin: actual receipt date (for reports)
  batchNumber          String?   // Admin: batch for traceability
  createdAt            DateTime  @default(now())

  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id])
  customsDeclaration CustomsDeclaration? @relation(fields: [customsDeclarationId], references: [id], onDelete: SetNull)

  @@index([warehouseId])
  @@index([productId])
  @@index([customsDeclarationId])
  @@map("inventory_movements")
}

// Orders
model Order {
  id                String        @id @default(uuid())
  userId            String
  orderNumber       String        @unique
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentMethod     String? // "GATEWAY" | "BANK_TRANSFER"
  paymentGatewayType String? // "STRIPE" | "YOOKASSA" | ... for GATEWAY orders
  subtotal          Decimal       @db.Decimal(10, 2)
  tax               Decimal       @default(0) @db.Decimal(10, 2)
  shipping          Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  loyaltyDiscount   Decimal       @default(0) @db.Decimal(10, 2)
  loyaltyPointsSpent Int          @default(0)
  // Currency chosen at checkout; PSP charge amounts are converted from USD totals using this code.
  checkoutCurrency  String        @default("USD")
  // Frozen active rates at order time (same shape as currencyRateService.getActive); used for PSP conversion & audits.
  checkoutFxCapturedAt    DateTime?
  checkoutFxRatesSnapshot Json?
  shippingAddressId String?
  notes             String?       @db.Text
  // Admin-only: delivery & invoicing (reports)
  invoiceNumber     String?
  invoiceDate       DateTime?
  shippedAt         DateTime?
  deliveryMethod    String?       // COURIER, POST, PICKUP, etc.
  carrierName       String?
  waybillNumber     String?
  waybillDate       DateTime?
  trackingNumber    String?        // Admin: track number for delivery report
  customsDeclarationNumber String? // Admin: declaration number for export/import
  // Multi-channel: source & fulfillment warehouse
  orderSource            OrderSource? @default(STORE_ONLINE)
  fulfillmentWarehouseId  String?     // Warehouse from which to fulfill
  salesPointId           String?      // Sales point (marketplace/store) this order came from
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user               User                 @relation(fields: [userId], references: [id])
  fulfillmentWarehouse Warehouse?         @relation("OrderFulfillmentWarehouse", fields: [fulfillmentWarehouseId], references: [id], onDelete: SetNull)
  salesPoint         SalesPoint?          @relation(fields: [salesPointId], references: [id], onDelete: SetNull)
  shippingAddress    CustomerAddress?     @relation(fields: [shippingAddressId], references: [id])
  promoCodeId        String?
  promoCode          PromoCode?           @relation(fields: [promoCodeId], references: [id])
  paymentRequest     PaymentRequest?
  items              OrderItem[]
  statusHistory      OrderStatusHistory[]
  inventoryItems     InventoryItem[]
  qrCodes            DeliveryQRCode[]
  tickets            SupportTicket[]
  returnRequests     ReturnRequest[]
  customsDeclarations CustomsDeclaration[]
  partnerCommissions PartnerCommission[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([orderSource])
  @@index([fulfillmentWarehouseId])
  @@index([salesPointId])
  @@index([paymentStatus])
  @@index([paymentMethod])
  @@index([paymentGatewayType])
  @@index([shippedAt])
  @@map("orders")
}

// Customs declarations (admin-only, for reports & accounting)
enum CustomsDirection {
  IMPORT
  EXPORT
}

model CustomsDeclaration {
  id                        String           @id @default(uuid())
  declarationNumber         String
  declarationDate           DateTime
  direction                 CustomsDirection
  customsOffice             String?
  customsProcedure          String?          // e.g. IM40, EK10 (RF)
  totalCustomsValue         Decimal?         @db.Decimal(12, 2)
  totalCustomsValueCurrency String?
  vatAmount                 Decimal?         @db.Decimal(12, 2)
  dutyAmount                Decimal?         @db.Decimal(12, 2)
  orderId                   String?         // when declaration is for order export/import
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  order     Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  movements InventoryMovement[]

  @@index([orderId])
  @@index([declarationNumber])
  @@index([declarationDate])
  @@index([direction])
  @@map("customs_declarations")
}

// Accounting: plan of accounts & entry templates (constructor for bookkeeping entries)
enum AccountingAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model AccountingChart {
  id        String   @id @default(uuid())
  region    String   // RU | CN | EU
  name      String   // e.g. "Payment Plan"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     AccountingChartItem[]
  templates AccountingEntryTemplate[]

  @@index([region])
  @@index([isActive])
  @@map("accounting_charts")
}

model AccountingChartItem {
  id       String              @id @default(uuid())
  chartId  String
  code     String   // e.g. "51", "62"
  name     String
  type     AccountingAccountType
  createdAt DateTime @default(now())

  chart AccountingChart @relation(fields: [chartId], references: [id], onDelete: Cascade)

  @@unique([chartId, code])
  @@index([chartId])
  @@map("accounting_chart_items")
}

model AccountingEntryTemplate {
  id                 String   @id @default(uuid())
  chartId            String?
  region             String   // RU | CN | EU
  legalRegime        String?  // RU_OSN | RU_USN | EU_OSS | etc.
  name               String
  triggerEvent       String   // ORDER_PAID | ORDER_SHIPPED | ORDER_DELIVERED | INVENTORY_RECEIVED | RETURN_ACCEPTED | CUSTOMS_IMPORT_REGISTERED
  debitAccountCode   String
  creditAccountCode  String
  amountFormula      String?  @db.Text // e.g. "order.total", "movement.quantity * movement.purchasePrice"
  analyticsMapping   Json?    // optional analytics per dimension
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  chart   AccountingChart? @relation(fields: [chartId], references: [id], onDelete: SetNull)
  entries AccountingEntry[]

  @@index([region])
  @@index([legalRegime])
  @@index([triggerEvent])
  @@index([chartId])
  @@map("accounting_entry_templates")
}

model AccountingEntry {
  id                  String   @id @default(uuid())
  templateId          String?
  region              String
  legalRegime         String?
  entityType          String   // order | inventory_movement | customs_declaration | return_request
  entityId            String
  eventDate           DateTime
  amount              Decimal  @db.Decimal(12, 2)
  currency            String   @default("RUB")
  debitAccountCode    String
  creditAccountCode   String
  debitAccountName    String?
  creditAccountName   String?
  analytics           Json?    // e.g. { orderNumber, customerEmail }
  createdAt           DateTime @default(now())

  template AccountingEntryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([region])
  @@index([entityType])
  @@index([entityId])
  @@index([eventDate])
  @@map("accounting_entries")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  variantId String?
  size      String? // Selected size (e.g., "M", "42", "50cm")
  quantity  Int
  price     Decimal? @db.Decimal(10, 2) // Nullable for price on request items
  createdAt DateTime @default(now())

  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product             @relation(fields: [productId], references: [id])
  variant            ProductVariant?     @relation(fields: [variantId], references: [id])
  returnRequestItems ReturnRequestItem[]

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?     @db.Text
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

// Support Tickets
model SupportTicket {
  id                String    @id @default(uuid())
  orderId           String?   // Optional: admin can create ticket for customer without order (proactive support)
  userId            String
  subject           String
  status            TicketStatus @default(OPEN)
  source            SupportTicketSource @default(MANUAL)
  priority          SupportTicketPriority @default(NORMAL)
  category          String?
  adminId           String? // Admin handling the ticket
  customerLastReadAt DateTime? // When customer last opened the ticket (for unread admin replies)
  resolutionSummary String? @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  resolvedAt        DateTime?

  order    Order?                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportTicketMessage[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([adminId])
  @@index([source, status, updatedAt])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String // User who sent the message (customer or admin)
  message   String   @db.Text
  isAdmin   Boolean  @default(false) // True if message is from admin
  source    SupportTicketMessageSource @default(CUSTOMER)
  aiConversationMessageId String?
  editedByAdminId String?
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
  @@index([source])
  @@map("support_ticket_messages")
}

// Lookbook
model Lookbook {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  season      String?
  year        Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images       LookbookImage[]
  translations LookbookTranslation[]

  @@index([slug])
  @@index([isActive])
  @@map("lookbooks")
}

model LookbookImage {
  id         String   @id @default(uuid())
  lookbookId String
  url        String
  alt        String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  lookbook    Lookbook             @relation(fields: [lookbookId], references: [id], onDelete: Cascade)
  productTags LookbookProductTag[]

  @@index([lookbookId])
  @@map("lookbook_images")
}

model LookbookProductTag {
  id              String   @id @default(uuid())
  lookbookImageId String
  productId       String
  x               Float // Position X (0-1)
  y               Float // Position Y (0-1)
  createdAt       DateTime @default(now())

  lookbookImage LookbookImage @relation(fields: [lookbookImageId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([lookbookImageId])
  @@index([productId])
  @@map("lookbook_product_tags")
}

// Homepage
model HomepageSection {
  id        String   @id @default(uuid())
  type      String // "hero", "collection", "editorial", "lookbook_preview"
  title     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  config    Json? // Flexible configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations HomepageSectionTranslation[]

  @@index([order])
  @@index([isActive])
  @@map("homepage_sections")
}

// Pages (About, Contact, Shipping, Returns, etc.)
model Page {
  id              String   @id @default(uuid())
  slug            String   @unique // "about", "contact", "shipping", "returns"
  title           String
  content         String?  @db.Text // HTML content
  metaTitle       String?
  metaDescription String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  translations PageTranslation[]

  @@index([slug])
  @@index([isActive])
  @@map("pages")
}

// Footer
model Footer {
  id          String   @id @default(uuid())
  brandName  String   @default("LOGO")
  tagline     String? // e.g. "Style that defines you"
  columns     Json // Array of footer columns with links
  copyright   String   @default("© {year} LOGO. All rights reserved.")
  links       Json? // Additional links (privacy, terms, etc.)
  socialLinks Json? // Follow us: instagram, tiktok, facebook, youtube URLs
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations FooterTranslation[]

  @@map("footers")
}

model FooterTranslation {
  id           String   @id @default(uuid())
  footerId     String
  languageCode String // ISO 639-1 (e.g., "en", "ru")
  brandName    String?
  tagline      String?
  columns      Json? // Translated columns
  copyright    String?
  links        Json? // Translated links
  socialLinks  Json? // Translated social links (optional)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  footer Footer @relation(fields: [footerId], references: [id], onDelete: Cascade)

  @@unique([footerId, languageCode])
  @@index([footerId])
  @@index([languageCode])
  @@map("footer_translations")
}

// Customer
model CustomerAddress {
  id         String   @id @default(uuid())
  userId     String
  firstName  String
  lastName   String
  phone      String?
  address    String
  city       String
  country    String
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("customer_addresses")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String? // For guest users
  productId String
  variantId String?
  size      String? // Selected size (e.g., "M", "42", "50cm")
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("cart_items")
}

// Admin
model AdminNote {
  id        String   @id @default(uuid())
  userId    String? // Customer ID
  orderId   String?
  content   String   @db.Text
  createdBy String // Admin user ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@map("admin_notes")
}

// Admin Permissions
model AdminPermissions {
  id                  String   @id @default(uuid())
  userId              String   @unique
  // Permission flags
  canManageSupport    Boolean  @default(false) // Support only
  canManageOrders     Boolean  @default(false) // Order processing
  canManageInventory  Boolean  @default(false) // Warehouse management
  canManagePayments   Boolean  @default(false) // Payment methods
  canManageProducts   Boolean  @default(false) // Products
  canManageCategories Boolean  @default(false) // Categories
  canManageBrands     Boolean  @default(false) // Brands
  canManageCustomers  Boolean  @default(false) // Customers
  canManagePromoCodes Boolean  @default(false) // Promo codes
  canManageContent    Boolean  @default(false) // Content (homepage, pages, lookbook)
  canManageSettings   Boolean  @default(false) // System settings
  canViewReports      Boolean  @default(false) // Reports
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_permissions")
}

// Admin Activity Logs
model AdminActivityLog {
  id          String   @id @default(uuid())
  adminId     String // Admin who performed the action
  createdById String? // Admin who created this admin (for admin creation logs)
  action      String // Action type: "CREATE_ADMIN", "UPDATE_ADMIN", "DEACTIVATE_ADMIN", "MANAGE_ORDER", etc.
  entityType  String? // Entity type: "USER", "ORDER", "PRODUCT", "INVENTORY", etc.
  entityId    String? // Entity ID
  details     Json? // Additional details about the action
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  admin     User  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdBy User? @relation("CreatedByAdmin", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([createdById])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("admin_activity_logs")
}

// Promo Codes & Discounts
model PromoCode {
  id                    String   @id @default(uuid())
  code                  String   @unique
  description           String?  @db.Text
  discountType          String // "PERCENTAGE" | "FIXED" | "BALANCE"
  discountValue         Decimal  @db.Decimal(10, 2)
  minPurchase           Decimal? @db.Decimal(10, 2)
  maxDiscount           Decimal? @db.Decimal(10, 2)
  usageLimit            Int?
  usedCount             Int      @default(0)
  validFrom             DateTime
  validUntil            DateTime
  isActive              Boolean  @default(true)
  isPartnerPromo        Boolean  @default(false) // Is this a partner promo code
  partnerId             String? // Partner who created this promo code
  partnerCommissionRate Decimal? @db.Decimal(5, 2) // Partner commission rate (e.g., 10.00 for 10%)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  orders             Order[]
  User               User?               @relation(fields: [userId], references: [id])
  userId             String?
  partner            User?               @relation("PartnerPromoCodes", fields: [partnerId], references: [id])
  partnerCommissions PartnerCommission[]

  @@index([code])
  @@index([isActive])
  @@index([isPartnerPromo])
  @@index([partnerId])
  @@map("promo_codes")
}

// Reviews & Ratings
model ProductReview {
  id          String   @id @default(uuid())
  productId   String
  userId      String
  orderId     String? // Optional: link to order
  rating      Int // 1-5
  title       String?
  comment     String?  @db.Text
  isVerified  Boolean  @default(false) // Verified purchase
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId]) // One review per user per product
  @@index([productId])
  @@index([userId])
  @@index([rating])
  @@map("product_reviews")
}

// Loyalty Program
model LoyaltyPoints {
