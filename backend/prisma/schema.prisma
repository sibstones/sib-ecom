  categoryLinksPosition    String   @default("LEFT") // "LEFT" | "CENTER" | "RIGHT"
  categoryLinksColor       String   @default("#4b5563")
  categoryLinksHoverColor  String   @default("#000000")
  categoryLinksActiveColor String   @default("#000000")
  categoryLinksFontSize    String   @default("text-sm")
  categoryLinksFontWeight  String   @default("font-medium")
  headerMenuDropdown       Boolean  @default(false) // Apple-style full-width dropdown menu on hover
