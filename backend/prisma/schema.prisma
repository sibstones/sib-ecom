  @@index([isActive])
  @@index([isDefault])
  @@map("languages")
}

// Payment Gateway Settings
model PaymentGateway {
  id                  String   @id @default(uuid())
  type                String   @unique // "STRIPE" | "PAYPAL" | "SQUARE" | etc.
  name                String
  isEnabled           Boolean  @default(false)
  isTestMode          Boolean  @default(true)
  config              Json // Gateway-specific configuration (API keys, etc.)
  supportedCountries  String[] // Array of country codes
  supportedCurrencies String[] // Array of currency codes
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
